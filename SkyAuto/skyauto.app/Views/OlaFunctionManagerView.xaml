<UserControl x:Class="SkyAuto.App.Views.OlaFunctionManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with controls -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="OLA 全量函数管理" Style="{StaticResource SectionHeaderStyle}" VerticalAlignment="Center"/>
            <Button Content="初始化全部函数状态" Style="{StaticResource PrimaryButtonStyle}" Margin="20,0,5,0" Click="OnInitializeAllClick"/>
            <Button Content="刷新" Click="OnRefreshClick" Margin="5,0"/>
            <TextBlock Text="筛选: " VerticalAlignment="Center" Margin="15,0,5,0"/>
            <ComboBox x:Name="CategoryFilterBox" Width="120" SelectionChanged="OnCategoryFilterChanged">
                <ComboBoxItem Content="全部" IsSelected="True"/>
            </ComboBox>
            <TextBox x:Name="SearchBox" Width="200" Margin="15,0,5,0" Padding="3" TextChanged="OnSearchTextChanged" ToolTip="搜索函数名..."/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid x:Name="FunctionStatusGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserResizeRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="70"/>
                <DataGridTextColumn Header="中文名称" Binding="{Binding ChineseName}" Width="100"/>
                <DataGridTextColumn Header="FunctionKey" Binding="{Binding FunctionKey}" Width="120"/>
                <DataGridTextColumn Header="OLA原始函数名" Binding="{Binding RawFunctionName}" Width="140"/>
                <DataGridTemplateColumn Header="已封装" Width="50">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Implemented, StringFormat={}{0}}" Foreground="{Binding Implemented, Converter={StaticResource BoolToColorConverter}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Real接入" Width="55">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RealOlaConnected, StringFormat={}{0}}" Foreground="{Binding RealOlaConnected, Converter={StaticResource BoolToColorConverter}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="测试状态" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TestStatus}" Foreground="{Binding TestStatus, Converter={StaticResource BoolToColorConverter}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="失败原因" Binding="{Binding TestMessage}" Width="*"/>
                <DataGridTextColumn Header="最后测试时间" Binding="{Binding LastTestedAt, StringFormat={}{0:HH:mm:ss}}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status bar -->
        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,10,0,0">
            <TextBlock x:Name="StatusBarText" Foreground="#718096"/>
        </StackPanel>
    </Grid>
</UserControl>
