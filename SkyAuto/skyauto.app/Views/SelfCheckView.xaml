<UserControl x:Class="SkyAuto.App.Views.SelfCheckView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <TextBlock Text="自检轮询" Style="{StaticResource SectionHeaderStyle}"/>

            <!-- Summary -->
            <WrapPanel x:Name="SummaryPanel" Margin="0,0,0,15">
                <Border Background="#F7FAFC" BorderBrush="#E2E8F0" CornerRadius="5" Padding="10" Margin="3">
                    <TextBlock Text="总计: 0/0" FontSize="14" FontWeight="SemiBold"/>
                </Border>
                <Border Background="#F0FFF4" BorderBrush="#C6F6D5" CornerRadius="5" Padding="10" Margin="3">
                    <TextBlock Text="通过: 0" Foreground="#38A169" FontSize="14"/>
                </Border>
                <Border Background="#FFF5F5" BorderBrush="#FED7D7" CornerRadius="5" Padding="10" Margin="3">
                    <TextBlock Text="失败: 0" Foreground="#E53E3E" FontSize="14"/>
                </Border>
            </WrapPanel>

            <!-- Actions -->
            <WrapPanel Margin="0,0,0,15">
                <Button Content="开始自检" Style="{StaticResource PrimaryButtonStyle}" Click="OnStartCheckClick"/>
                <Button Content="重新检查失败项" Margin="8,0" Background="#ED8936" Foreground="White" Click="OnRerunFailedClick"/>
                <Button Content="导出报告" Margin="8,0" Click="OnExportReportClick"/>
            </WrapPanel>

            <!-- Results table -->
            <DataGrid x:Name="CheckResultsGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="编号" Binding="{Binding Id}" Width="80"/>
                    <DataGridTextColumn Header="检查项" Binding="{Binding Name}" Width="200"/>
                    <DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="70"/>
                    <DataGridTemplateColumn Header="状态" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Status, StringFormat={}{0}}" FontWeight="SemiBold"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="证据/详情" Binding="{Binding Evidence}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Progress -->
            <ProgressBar x:Name="CheckProgress" Height="8" Margin="0,10" Visibility="Collapsed" Maximum="30"/>

            <TextBlock x:Name="StatusText" Foreground="#718096" Margin="0,10,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
