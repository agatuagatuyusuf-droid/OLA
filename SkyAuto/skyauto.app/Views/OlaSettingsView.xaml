<UserControl x:Class="SkyAuto.App.Views.OlaSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <TextBlock Text="OLA 设置" Style="{StaticResource SectionHeaderStyle}"/>

            <!-- Mode display -->
            <GroupBox Header="连接模式" Margin="0,0,0,15">
                <StackPanel Margin="10">
                    <WrapPanel>
                        <TextBlock Text="当前模式: " Width="60" FontWeight="SemiBold"/>
                        <TextBlock x:Name="ModeDisplay" FontSize="14" FontWeight="Bold" Foreground="#718096"/>
                    </WrapPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,10">
                        <Button x:Name="BtnSwitchMock" Content="切换到 Mock 模式" Style="{StaticResource PrimaryButtonStyle}" Click="OnSwitchToMockClick" IsEnabled="False"/>
                        <Button x:Name="BtnSwitchReal" Content="切换到 Real 模式" Margin="5,0" Style="{StaticResource PrimaryButtonStyle}" Click="OnSwitchToRealClick" IsEnabled="True"/>
                    </StackPanel>

                    <TextBlock x:Name="ModeDescription" Foreground="#718096" TextWrapping="Wrap" Margin="0,5"/>
                </StackPanel>
            </GroupBox>

            <!-- Plugin settings -->
            <GroupBox Header="插件配置" Margin="0,0,0,15">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="OLA 插件路径: " Width="90"/>
                        <TextBox x:Name="PluginPathBox" Width="300" Height="26" Padding="3"/>
                        <Button Content="浏览..." Margin="5,0" Click="OnBrowseClick"/>
                    </StackPanel>

                    <WrapPanel Margin="0,10">
                        <Button Content="保存路径并初始化" Style="{StaticResource PrimaryButtonStyle}" Click="OnInitConnectionClick"/>
                        <Button Content="测试连接" Margin="5,0" Click="OnTestConnectionClick"/>
                        <Button Content="断开连接" Margin="5,0" Click="OnDisconnectClick"/>
                    </WrapPanel>

                    <TextBlock x:Name="ConnectionStatus" Foreground="#718096" Margin="0,5"/>
                </StackPanel>
            </GroupBox>

            <!-- Status -->
            <GroupBox Header="状态信息" Margin="0,0,0,15">
                <StackPanel Margin="10">
                    <TextBlock Text="机器码: " FontWeight="SemiBold"/>
                    <TextBox x:Name="MachineCodeBox" IsReadOnly="True" Height="26" Padding="3" Margin="0,3"/>

                    <TextBlock Text="初始化状态: " FontWeight="SemiBold" Margin="0,8,0,0"/>
                    <TextBlock x:Name="InitStatus" Foreground="#718096" Margin="0,3"/>

                    <TextBlock Text="日志路径: " FontWeight="SemiBold" Margin="0,8,0,0"/>
                    <TextBox x:Name="LogPathBox" IsReadOnly="True" Height="26" Padding="3" Margin="0,3"/>

                    <TextBlock Text="截图路径: " FontWeight="SemiBold" Margin="0,8,0,0"/>
                    <TextBox x:Name="ScreenshotPathBox" IsReadOnly="True" Height="26" Padding="3" Margin="0,3"/>

                    <Button Content="打开数据目录" Style="{StaticResource PrimaryButtonStyle}" Margin="0,15,0,0" Click="OnOpenDataDirClick"/>
                </StackPanel>
            </GroupBox>

            <!-- Registered functions -->
            <GroupBox Header="已注册动作">
                <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                    <ListBox x:Name="RegisteredFunctionsList" Margin="5"/>
                </ScrollViewer>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
