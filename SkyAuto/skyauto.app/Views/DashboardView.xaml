<UserControl x:Class="SkyAuto.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <TextBlock Text="首页总览" Style="{StaticResource SectionHeaderStyle}"/>

            <!-- Stats cards -->
            <UniformGrid Columns="4" Margin="0,0,0,15">
                <Border Background="#EBF8FF" CornerRadius="5" Padding="15" Margin="3">
                    <StackPanel>
                        <TextBlock Text="今日执行" FontSize="12" Foreground="#718096"/>
                        <TextBlock x:Name="TodayRunsCount" Text="-" FontSize="24" FontWeight="Bold" Foreground="#3182CE"/>
                    </StackPanel>
                </Border>
                <Border Background="#F0FFF4" CornerRadius="5" Padding="15" Margin="3">
                    <StackPanel>
                        <TextBlock Text="成功次数" FontSize="12" Foreground="#718096"/>
                        <TextBlock x:Name="SuccessCount" Text="-" FontSize="24" FontWeight="Bold" Foreground="#38A169"/>
                    </StackPanel>
                </Border>
                <Border Background="#FFF5F5" CornerRadius="5" Padding="15" Margin="3">
                    <StackPanel>
                        <TextBlock Text="失败次数" FontSize="12" Foreground="#718096"/>
                        <TextBlock x:Name="FailCount" Text="-" FontSize="24" FontWeight="Bold" Foreground="#E53E3E"/>
                    </StackPanel>
                </Border>
                <Border Background="#F5F3FF" CornerRadius="5" Padding="15" Margin="3">
                    <StackPanel>
                        <TextBlock Text="流程总数" FontSize="12" Foreground="#718096"/>
                        <TextBlock x:Name="WorkflowCount" Text="-" FontSize="24" FontWeight="Bold" Foreground="#5A67D8"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Status section -->
            <WrapPanel Margin="0,0,0,15">
                <TextBlock Text="OLA 插件状态: " FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock x:Name="OlaStatus" Style="{StaticResource StatusPassBadge}" Text="已注册" Margin="5,0"/>

                <TextBlock Text="定时任务状态: " FontWeight="SemiBold" Margin="20,0,0,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="ScheduleStatus" Style="{StaticResource StatusPassBadge}" Text="运行中" Margin="5,0"/>

                <TextBlock Text="自检状态: " FontWeight="SemiBold" Margin="20,0,0,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="SelfCheckStatus" Style="{StaticResource StatusPassBadge}" Text="待检查" Margin="5,0"/>
            </WrapPanel>

            <!-- Recent failures -->
            <Border BorderBrush="#E2E8F0" CornerRadius="5">
                <StackPanel Margin="10">
                    <TextBlock Text="最近失败流程" FontWeight="SemiBold" Foreground="#4A5568"/>
                    <DataGrid x:Name="RecentFailuresGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Margin="0,5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="流程名称" Binding="{Binding WorkflowName}" Width="150"/>
                            <DataGridTextColumn Header="失败时间" Binding="{Binding EndTime, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="130"/>
                            <DataGridTextColumn Header="失败步骤" Binding="{Binding FailedStepName}" Width="200"/>
                            <DataGridTextColumn Header="错误信息" Binding="{Binding ErrorMessage}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Quick actions -->
            <UniformGrid Columns="4" Margin="0,15">
                <Button Content="+ 新建自动化" Style="{StaticResource PrimaryButtonStyle}" Height="36" HorizontalAlignment="Center" Click="OnNewWorkflowClick"/>
                <Button Content="立即自检" Background="#48BB78" Foreground="White" Height="36" HorizontalAlignment="Center" Margin="5,0" Click="OnSelfCheckClick"/>
                <Button Content="查看日志" Height="36" HorizontalAlignment="Center" Margin="5,0" Click="OnViewLogsClick"/>
                <Button Content="打开 OLA 设置" Height="36" HorizontalAlignment="Center" Margin="5,0" Click="OnOlaSettingsClick"/>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
