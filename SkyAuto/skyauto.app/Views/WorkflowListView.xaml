<UserControl x:Class="SkyAuto.App.Views.WorkflowListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <TextBlock Text="自动化列表" Style="{StaticResource SectionHeaderStyle}"/>

            <!-- Toolbar -->
            <WrapPanel Margin="0,0,0,10">
                <Button Content="+ 新建流程" Style="{StaticResource PrimaryButtonStyle}" Click="OnNewWorkflowClick" HorizontalAlignment="Left"/>
                <Button Content="导入 JSON" Margin="8,0,0,0" Click="OnImportJsonClick"/>
                <TextBox x:Name="SearchBox" Width="200" Height="30" Margin="15,0,0,0" Padding="5,3" VerticalContentAlignment="Center" TextChanged="OnSearchTextChanged">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="3"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
            </WrapPanel>

            <!-- Workflow table -->
            <DataGrid x:Name="WorkflowGrid" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single" Margin="0,0,0,10">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="启用" Binding="{Binding Enabled}" Width="50"/>
                    <DataGridTextColumn Header="流程名称" Binding="{Binding Name}" Width="200"/>
                    <DataGridTextColumn Header="步骤数" Binding="{Binding Steps.Count}" Width="70"/>
                    <DataGridCheckBoxColumn Header="有定时" Binding="{Binding HasSchedule}" Width="60"/>
                    <DataGridTextColumn Header="最近执行时间" Binding="{Binding LastRunTime, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="130"/>
                    <DataGridTextColumn Header="最近结果" Binding="{Binding LastResult}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Action buttons for selected workflow -->
            <WrapPanel x:Name="ActionButtons" Visibility="Collapsed">
                <Button Content="运行" Style="{StaticResource PrimaryButtonStyle}" Click="OnRunWorkflowClick"/>
                <Button Content="编辑" Margin="5,0" Click="OnEditWorkflowClick"/>
                <Button Content="复制" Margin="5,0" Click="OnCopyWorkflowClick"/>
                <Button Content="导出 JSON" Margin="5,0" Click="OnExportJsonClick"/>
                <Button Content="删除" Style="{StaticResource DangerButtonStyle}" Margin="5,0" Click="OnDeleteWorkflowClick"/>
                <Button Content="查看日志" Margin="5,0" Click="OnViewLogsClick"/>
            </WrapPanel>

            <!-- Status text -->
            <TextBlock x:Name="StatusText" Foreground="#718096" Margin="0,10,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
