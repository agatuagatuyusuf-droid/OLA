<UserControl x:Class="SkyAuto.App.Views.RunLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="10">
        <TextBlock Text="执行日志" Style="{StaticResource SectionHeaderStyle}" DockPanel.Dock="Top"/>

        <!-- Filter -->
        <WrapPanel DockPanel.Dock="Top" Margin="0,5,0,10">
            <Button Content="刷新" Click="OnRefreshClick"/>
            <TextBlock Text="筛选流程ID: " VerticalAlignment="Center" Margin="20,0,0,0"/>
            <TextBox x:Name="FilterWorkflowId" Width="180" Height="26" Padding="3" KeyDown="OnFilterKeyDown"/>
        </WrapPanel>

        <!-- Summary table -->
        <DataGrid x:Name="LogSummaryGrid" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="流程名称" Binding="{Binding WorkflowName}" Width="150"/>
                <DataGridTextColumn Header="开始时间" Binding="{Binding StartTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="120"/>
                <DataGridTextColumn Header="结束时间" Binding="{Binding EndTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="120"/>
                <DataGridTextColumn Header="耗时(ms)" Binding="{Binding DurationMs}" Width="70"/>
                <DataGridTemplateColumn Header="结果" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Success, StringFormat={}{0}}" Foreground="{Binding Success, Converter={StaticResource BoolToColorConverter}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="失败步骤" Binding="{Binding FailedStepName}" Width="150"/>
                <DataGridTextColumn Header="错误信息" Binding="{Binding ErrorMessage}" Width="*"/>
                <DataGridTemplateColumn Header="失败截图" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="查看" Click="OnViewScreenshotClick"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Detail -->
        <GroupBox x:Name="DetailGroup" Header="步骤详情" Visibility="Collapsed" DockPanel.Dock="Bottom" Height="200" Margin="0,10">
            <DataGrid x:Name="StepDetailGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="序号" Binding="{Binding Index}" Width="45"/>
                    <DataGridTextColumn Header="动作名称" Binding="{Binding StepName}" Width="120"/>
                    <DataGridTextColumn Header="开始时间" Binding="{Binding StartTime, StringFormat={}{0:HH:mm:ss.fff}}" Width="95"/>
                    <DataGridTextColumn Header="耗时(ms)" Binding="{Binding DurationMs}" Width="65"/>
                    <DataGridTemplateColumn Header="状态" Width="45">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Success, StringFormat={}{0}}" Foreground="{Binding Success, Converter={StaticResource BoolToColorConverter}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="输出" Binding="{Binding OutputData}" Width="200"/>
                    <DataGridTextColumn Header="错误" Binding="{Binding Error}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </DockPanel>
</UserControl>
